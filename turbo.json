{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "@pqc-sdk/cli#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@pqc-sdk/docs#build": {
      "dependsOn": ["^build"],
      "outputs": ["api/**", "compatibility.md", ".vitepress/dist/**"]
    },
    "lint": {
      "dependsOn": ["^build", "//#format:check"]
    },
    "//#format:check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
