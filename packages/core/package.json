{
  "name": "@pqc-sdk/core",
  "version": "0.1.0",
  "description": "SDK de criptografía post-cuántica para JS/TS (ML-KEM, ML-DSA, SLH-DSA)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit"
  },
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@vitest/coverage-v8": "^3.2.2",
    "tsup": "^8.5.0",
    "vitest": "^3.2.2"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/post-quantum": "^0.6.1"
  },
  "license": "MIT",
  "homepage": "https://github.com/jeloercc/pqc-sdk#readme",
  "bugs": "https://github.com/jeloercc/pqc-sdk/issues",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "post-quantum",
    "pqc",
    "ml-kem",
    "ml-dsa",
    "fips-203",
    "fips-204",
    "kyber",
    "dilithium",
    "cryptography",
    "encryption"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeloercc/pqc-sdk.git",
    "directory": "packages/core"
  }
}
