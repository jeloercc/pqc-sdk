  },
  "dependencies": {
    "@pqc-sdk/core": "workspace:*",
    "citty": "^0.2.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsup": "^8.5.0",
    "typescript": "5.8.3",
    "vitest": "^3.2.6"
  },
  "license": "MIT",
  "homepage": "https://jeloercc.github.io/pqc-sdk/",
