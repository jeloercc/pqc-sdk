{
  "name": "@pqc-sdk/cli",
  "version": "0.3.3",
  "description": "CLI for the post-quantum cryptography SDK",
  "type": "module",
  "bin": {
    "pqc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
